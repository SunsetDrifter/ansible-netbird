---
# NetBird Setup Keys
# Exported from {{ netbird_api_url }} on {{ ansible_date_time.date }}
#
# Total setup keys: {{ setup_keys_data.data | length }}
# Note: Key values are generated by the API and not stored here.
# Note: After creation, only auto_groups and revoked can be updated.
#
# Reference: https://docs.netbird.io/api/resources/setup-keys

netbird_setup_keys:
{% for key in setup_keys_data.data | sort(attribute='name') %}
  - name: "{{ key.name }}"
    key_type: "{{ key.type | default('one-off') }}"
{% if key.expires_in is defined %}
    expires_in: {{ key.expires_in }}
{% endif %}
{% if key.auto_groups is defined and key.auto_groups is not none and key.auto_groups | length > 0 %}
    auto_groups:
{% for gid in key.auto_groups %}
      - {{ group_id_map[gid] | default(gid) }}
{% endfor %}
{% else %}
    auto_groups: []
{% endif %}
{% if key.usage_limit is defined %}
    usage_limit: {{ key.usage_limit }}
{% endif %}
    ephemeral: {{ key.ephemeral | default(false) | lower }}
{% if key.allow_extra_dns_labels is defined and key.allow_extra_dns_labels %}
    allow_extra_dns_labels: true
{% endif %}
{% if key.revoked is defined and key.revoked %}
    revoked: true
{% endif %}
    state: present
{% endfor %}
{% if setup_keys_data.data | length == 0 %}
  []
{% endif %}
